X_ATUO_AI__PROVIDER=mock
X_ATUO_AI__BASE_URL=https://api.openai.com/v1
X_ATUO_AI__MODEL=gpt-4.1-mini
X_ATUO_AI__API_KEY=YOUR_API_KEY
X_ATUO_AI__TIMEOUT_SECONDS=90

X_ATUO_POLICIES__MAX_REPLY_LENGTH=250
X_ATUO_POLICIES__CANDIDATE_REFRESH_ROUNDS=2
X_ATUO_POLICIES__CANDIDATE_HYDRATION_COUNT=3
X_ATUO_POLICIES__CANDIDATE_CACHE_PENDING_TTL_MINUTES=60
X_ATUO_POLICIES__CANDIDATE_CACHE_REJECTED_TTL_MINUTES=1440
X_ATUO_POLICIES__CANDIDATE_CACHE_CLAIM_TTL_MINUTES=10

X_ATUO_SCHEDULER__ENABLED=true
X_ATUO_SCHEDULER__AUTOSTART=true
X_ATUO_SCHEDULER__FEED_ENGAGE_ENABLED=true
X_ATUO_SCHEDULER__FEED_ENGAGE_TRIGGER=interval
X_ATUO_SCHEDULER__FEED_ENGAGE_SECONDS=300
X_ATUO_SCHEDULER__FEED_ENGAGE_JITTER_SECONDS=20

X_ATUO_AUTHOR_ALPHA__ENABLED=false
X_ATUO_AUTHOR_ALPHA__DB_PATH=data/author_alpha.sqlite3
X_ATUO_AUTHOR_ALPHA__TIMEZONE=Asia/Shanghai
X_ATUO_AUTHOR_ALPHA__EXCLUDED_AUTHORS=[]
X_ATUO_AUTHOR_ALPHA__TRIGGER=interval
X_ATUO_AUTHOR_ALPHA__SECONDS=1200
X_ATUO_AUTHOR_ALPHA__JITTER_SECONDS=20
X_ATUO_AUTHOR_ALPHA__SCORE_MIN_DAILY_REPLIES=400
X_ATUO_AUTHOR_ALPHA__SCORE_PRIOR_WEIGHT=7.0
X_ATUO_AUTHOR_ALPHA__SCORE_PENALTY_CONSTANT=200.0
X_ATUO_AUTHOR_ALPHA__DEVICE_FOLLOW_FEED_COUNT=50
X_ATUO_AUTHOR_ALPHA__DAILY_EXECUTION_LIMIT=700
X_ATUO_AUTHOR_ALPHA__GLOBAL_SEND_LIMIT_15M=50
X_ATUO_AUTHOR_ALPHA__PER_AUTHOR_DAILY_SUCCESS_LIMIT=100
X_ATUO_AUTHOR_ALPHA__PER_TARGET_TWEET_SUCCESS_LIMIT=4
X_ATUO_AUTHOR_ALPHA__TARGET_REVISIT_COOLDOWN_SECONDS=3600
X_ATUO_AUTHOR_ALPHA__MAX_TARGETS_PER_RUN=5
X_ATUO_AUTHOR_ALPHA__PER_RUN_SAME_TARGET_BURST_LIMIT=2
X_ATUO_AUTHOR_ALPHA__POSTS_PER_AUTHOR=1
X_ATUO_AUTHOR_ALPHA__AUTHOR_COOLDOWN_SECONDS=3
X_ATUO_AUTHOR_ALPHA__INTER_REPLY_DELAY_SECONDS=5
X_ATUO_AUTHOR_ALPHA__TARGET_SWITCH_DELAY_SECONDS=10
